    "chai": "^4.5.0",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.4",
