# --- Local runs need NONE of this (the economy runs fully on a local Hardhat chain) ---

# --- Arc Testnet (only for live on-chain runs) ---
# A faucet-funded Arc Testnet private key. Get test USDC from https://faucet.circle.com
PRIVATE_KEY=0xYOUR_ARC_TESTNET_PRIVATE_KEY
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Circle Gateway facilitator (x402 settlement) — defaults are fine
GATEWAY_API=https://gateway-api-testnet.circle.com

# Settlement backend: "local" (real ERC-20 transfers on Hardhat) or "arc" (Circle Gateway/Nanopayments)
SETTLEMENT=local
